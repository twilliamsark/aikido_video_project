# Copy to .env and adjust. The server reads these at startup (server/env.ts).

# Path to the single SQLite file shared by better-auth and the domain tables.
DATABASE_URL=data/library.sqlite

# Bun API server port.
PORT=3000

# Public base URL of the API (used by better-auth for cookies/callbacks).
BETTER_AUTH_URL=http://localhost:3000

# REQUIRED in production: secret used to sign sessions. Generate a random value.
BETTER_AUTH_SECRET=dev-insecure-secret-change-me

# Origin allowed to call the API with credentials (Angular dev server).
WEB_ORIGIN=http://localhost:4200
